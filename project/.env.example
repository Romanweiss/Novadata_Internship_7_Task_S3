S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=your_bucket_name
S3_REGION=us-east-1
S3_PREFIX=processed/
S3_VERIFY_SSL=true
S3_CA_BUNDLE=
WATCH_DIR=./watch
ARCHIVE_DIR=./archive
LOG_FILE=./logs/pipeline.log
LOG_OBJECT_KEY=logs/pipeline.log
WATCH_USE_POLLING=false
